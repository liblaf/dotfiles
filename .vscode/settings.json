{
  "files.associations": {
    "*.json.tmpl": "json",
    "*.toml.tmpl": "toml"
  },
  "json.schemaDownload.trustedDomains": {
    "https://models.dev/model-schema.json": true,
    "https://opencode.ai/config.json": true
  },
  "json.schemas": [
    {
      "fileMatch": ["daemon.json.tmpl"],
      "url": "https://www.schemastore.org/dockerd.json"
    }
  ],
  "shellcheck.ignorePatterns": {
    "**/symlink_*": true
  },
  "xml.catalogs": [".vscode/catalog.xml"]
}
