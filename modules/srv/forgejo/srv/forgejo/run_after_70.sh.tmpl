#!/bin/bash
# -*- mode: sh; -*-
set -o errexit
set -o nounset
set -o pipefail

# {{ includeTemplate "docker.sh" }}
# {{ includeTemplate "service.sh" . }}

# {{ if .services.forgejo.enable }}

service-user-add 'forgejo' '{{ .services.forgejo.uid }}' 'Forgejo'
mkdir --parents --verbose './forgejo'
sudo chown --verbose 'forgejo:srv' './forgejo'
docker compose up --detach --remove-orphans

# {{ else }}

docker compose down

# {{ end }}
