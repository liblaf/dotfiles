# -*- mode: ini; -*-
# ref: <https://github.com/CachyOS/CachyOS-PKGBUILDS/blob/master/cachyos-rate-mirrors/cachyos-rate-mirrors.timer>

[Unit]
Description = Automatically refresh %I mirror lists
Wants = network-online.target
After = network-online.target

[Timer]
OnBootSec = 10min
RandomizedDelaySec = 30s
OnUnitActiveSec = 5d
Persistent = true

[Install]
WantedBy = timers.target
