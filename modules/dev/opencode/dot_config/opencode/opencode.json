// -*- mode: jsonc; -*-

{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git"],
      "enabled": true
    },
    "repomix": {
      "type": "local",
      "command": ["bunx", "repomix", "--mcp"],
      "enabled": true
    }
  },
  "tools": {
    "git_*": false,
    "repomix_*": false
  }
}
