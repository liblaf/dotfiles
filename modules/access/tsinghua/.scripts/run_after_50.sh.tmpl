#!/bin/bash
# -*- mode: sh; -*-
set -o errexit
set -o nounset
set -o pipefail

systemctl --user --now disable goauthing6.service
systemctl --user --now enable goauthing.service

# ref: <https://thu.services/services/#token>
rclone config create tsinghua seafile \
  url='https://cloud.tsinghua.edu.cn' \
  user='{{ (rbw "清华大学云盘").data.username }}' \
  auth_token='{{ (rbwFields "清华大学云盘").token.value }}'
systemctl --user --now enable rclone-mount@tsinghua.service

sudo systemctl --now enable mnt-DATA41.automount
sudo systemctl --now enable mnt-tsinghua.automount
