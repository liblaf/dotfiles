# -*- mode: ssh_config; -*-
# ref: <https://man.archlinux.org/man/sshd_config.5>
# ref: <https://wiki.archlinux.org/title/OpenSSH#Server_usage>

# TODO: add comments to explain the rationale behind each setting
AcceptEnv COLORTERM TERM TERMINFO
AuthenticationMethods publickey
PasswordAuthentication no
PermitRootLogin no
Port {{ .services.ssh.port }}
UsePAM yes
