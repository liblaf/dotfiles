# -*- mode: toml; -*-

sourceDir = '{{ joinPath .chezmoi.workingTree "home" }}'

[data]
baseDomain = "liblaf.me"

# {{- $cacheDirRel := joinPath ".cache" "dotfiles" -}}
# {{- $cacheDirAbs := joinPath .chezmoi.homeDir $cacheDirRel }}
[data.dirs.abs]
external = '{{ joinPath $cacheDirAbs "external" }}'
packages = '{{ joinPath $cacheDirAbs "packages" }}'
root = '{{ joinPath $cacheDirAbs "root" }}'

[data.dirs.rel]
external = '{{ joinPath $cacheDirRel "external" }}'

[hooks.read-source-state.pre]
script = '{{ joinPath .chezmoi.workingTree "hooks" "read-source-state.pre.sh" }}'

[interpreters.fish]
command = "fish"
